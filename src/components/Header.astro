---
import ThemeToggle from "./ThemeToggle.astro";
import HamburgerToggle from "./HamburgerToggle.astro";
---

<header class="bg-bg-warm/60 dark:bg-neutral-500/40 backdrop-blur-sm sticky top-0 z-50 py-4 px-6 mb-8 rounded-b-organic-lg shadow-sm mx-4 border-b border-neutral-warm/10 dark:border-neutral-400/10 transition-colors duration-400">
  <div class="container mx-auto flex justify-between items-center">
    <div class="text-accent-earth font-bold text-xl tracking-tight shrink-0">
      <a href="/" class="hover:opacity-80 transition-opacity">mi-web-personal</a>
    </div>
    
    <div class="flex items-center gap-4 lg:gap-8">
      <nav class="hidden lg:flex items-center">
        <ul class="flex space-x-8 text-text-main font-medium">
          <li><a href="/" class="hover:text-accent-earth transition-colors">Inicio</a></li>
          <li><a href="/blog" class="hover:text-accent-earth transition-colors">Blog</a></li>
          <li><a href="/sobre-mi" class="hover:text-accent-earth transition-colors">Sobre mí</a></li>
        </ul>
      </nav>
      
      <div class="flex items-center gap-4 border-l border-neutral-warm/20 dark:border-neutral-400/20 pl-4 lg:pl-6">
        <ThemeToggle />
        <HamburgerToggle />
      </div>
    </div>
  </div>
</header>
