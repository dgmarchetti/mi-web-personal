---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
}

const { title = "mi-web-personal" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col bg-bg-base text-text-main selection:bg-accent-green/30">
		<Header />
		<main class="flex-grow container mx-auto px-6 max-w-4xl py-12">
			<div class="bg-white/60 dark:bg-neutral-500/30 backdrop-blur-sm rounded-organic-lg p-8 md:p-12 shadow-sm border border-neutral-warm/20 dark:border-neutral-400/20 transition-colors duration-400">
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>
